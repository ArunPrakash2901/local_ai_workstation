{
  "version": "0.1",
  "global_slash_execution_supported": false,
  "status": "DOCUMENTED_ONLY",
  "notes": "Slash commands are short operator shortcuts. Canonical execution remains ws commands.",
  "commands": [
    {
      "command": "/design",
      "status": "PLANNED_MAPPING",
      "default_action": "Preview Open Design adapter for the current product",
      "maps_to": "ws product-design-adapter-preview --product <current_product> --tool open-design --dry-run",
      "subactions": {
        "preview": "ws product-design-adapter-preview --product <current_product> --tool open-design --dry-run",
        "render": "ws product-design-render --product <current_product> --tool open-design --dry-run",
        "prepare": "ws product-design-run-prepare --product <current_product> --tool open-design --confirm",
        "status": "ws product-design-run-status --product <current_product> --tool open-design",
        "probe": "ws product-design-runtime-probe --tool open-design --dry-run",
        "install-check": "ws product-design-install-checklist --tool open-design --dry-run",
        "runtime": "ws product-design-runtime-report --tool open-design --dry-run",
        "runtime-status": "ws product-design-runtime-status --tool open-design",
        "runtime-start": "ws product-design-runtime-start --tool open-design --dry-run",
        "runtime-stop": "ws product-design-runtime-stop --tool open-design --dry-run",
        "review": "ws product-design-run-review --product <current_product> --tool open-design --dry-run",
        "review-write": "ws product-design-run-review --product <current_product> --tool open-design --confirm"
      },
      "safety_class": "DRY_RUN_ONLY",
      "writes_local_files": false,
      "tool_execution": false
    },
    {
      "command": "/sessions",
      "status": "PLANNED_MAPPING",
      "default_action": "Show Runtime Session Lane status",
      "maps_to": "ws runtime status",
      "subactions": {
        "register": "ws runtime register --session-id <id> --adapter <adapter_id> --label <label> --cwd <path> --lane <lane> --task <task>",
        "blocker": "ws runtime report-blocker --session-id <id> --type <blocker_type> --description <description>",
        "audit": "ws runtime audit",
        "workload": "ws runtime workload",
        "assign": "ws runtime assign --session-id <id> --task-source <path> --label <label> --type <task_source_type>",
        "assignments": "ws runtime assignment-list",
        "unassigned": "ws runtime unassigned"
      },
      "safety_class": "PURE_READ",
      "writes_local_files": false,
      "tool_execution": false
    },
    {
      "command": "/exchange",
      "status": "PLANNED_MAPPING",
      "default_action": "Show Exchange Lane packet status",
      "maps_to": "ws exchange status",
      "subactions": {
        "status": "ws exchange status",
        "audit": "ws exchange audit",
        "packets": "ws exchange packet-list",
        "approve": "ws exchange approve-planning --packet-id <id> --note \"...\"",
        "plan": "ws exchange dispatch-plan --packet-id <id> --session-id <id> --assignment-id <id>",
        "plans": "ws exchange dispatch-plan-list",
        "plan-status": "ws exchange dispatch-plan-status --dispatch-plan-id <id>",
        "fake": "ws exchange fake-dispatch --dispatch-plan-id <id> --confirm",
        "results": "ws exchange result-list",
        "result-status": "ws exchange result-status --result-id <id>",
        "validate": "ws exchange validate-result --result-id <id>",
        "loop": "ws exchange loop-status",
        "repair": "ws exchange repair-plan --loop-decision-id <id>"
      },
      "safety_class": "PURE_READ",
      "writes_local_files": false,
      "tool_execution": false
    },
    {
      "command": "/dispatch",
      "status": "PLANNED_MAPPING",
      "default_action": "Fake dispatch an approved Exchange dispatch plan",
      "maps_to": "ws exchange fake-dispatch --dispatch-plan-id <id> --confirm",
      "subactions": {
        "fake": "ws exchange fake-dispatch --dispatch-plan-id <id> --confirm",
        "dry-run": "ws exchange real-dispatch --dispatch-plan-id <id> --dry-run",
        "real": "ws exchange real-dispatch --dispatch-plan-id <id> --confirm"
      },
      "safety_class": "GUARDED_WRITE",
      "writes_local_files": true,
      "tool_execution": false
    },
    {
      "command": "/import",
      "status": "PLANNED_MAPPING",
      "default_action": "Import an Exchange result capture manifest",
      "maps_to": "ws exchange import-result --capture-manifest <path> --confirm",
      "subactions": {
        "result": "ws exchange import-result --capture-manifest <path> --confirm"
      },
      "safety_class": "GUARDED_WRITE",
      "writes_local_files": true,
      "tool_execution": false
    },
    {
      "command": "/review",
      "status": "PLANNED_MAPPING",
      "default_action": "Audit Product Development review artifacts",
      "maps_to": "ws product-dev review-audit",
      "subactions": {
        "audit": "ws product-dev review-audit",
        "build": "ws product-dev review-html --manifest <current_product_dev_manifest>"
      },
      "safety_class": "PURE_READ",
      "writes_local_files": false,
      "tool_execution": false
    },
    {
      "command": "/exec",
      "status": "PLANNED_MAPPING",
      "default_action": "Show Execution Lane status",
      "maps_to": "ws execution status",
      "subactions": {
        "status": "ws execution status"
      },
      "safety_class": "PURE_READ",
      "writes_local_files": false,
      "tool_execution": false
    },
    {
      "command": "/impl",
      "status": "PLANNED_MAPPING",
      "default_action": "Dry-run execution planning for current queue",
      "maps_to": "ws execution plan --queue <current_queue> --dry-run",
      "subactions": {
        "plan": "ws execution plan --queue <current_queue> --dry-run"
      },
      "safety_class": "DRY_RUN_ONLY",
      "writes_local_files": false,
      "tool_execution": false
    },
    {
      "command": "/handoff",
      "status": "PLANNED_MAPPING",
      "default_action": "Dry-run execution handoff preview for current run",
      "maps_to": "ws execution handoff-preview --run <current_run> --target codex_cli --dry-run",
      "subactions": {
        "preview": "ws execution handoff-preview --run <current_run> --target codex_cli --dry-run"
      },
      "safety_class": "DRY_RUN_ONLY",
      "writes_local_files": false,
      "tool_execution": false
    }
  ]
}
