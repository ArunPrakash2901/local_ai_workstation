{
  "version": "0.1",
  "global_slash_execution_supported": false,
  "status": "DOCUMENTED_ONLY",
  "notes": "Slash commands are short operator shortcuts. Canonical execution remains ws commands.",
  "commands": [
    {
      "command": "/design",
      "status": "PLANNED_MAPPING",
      "default_action": "Preview Open Design adapter for the current product",
      "maps_to": "ws product-design-adapter-preview --product <current_product> --tool open-design --dry-run",
      "subactions": {
        "preview": "ws product-design-adapter-preview --product <current_product> --tool open-design --dry-run",
        "render": "ws product-design-render --product <current_product> --tool open-design --dry-run",
        "prepare": "ws product-design-run-prepare --product <current_product> --tool open-design --confirm",
        "status": "ws product-design-run-status --product <current_product> --tool open-design",
        "probe": "ws product-design-runtime-probe --tool open-design --dry-run",
        "install-check": "ws product-design-install-checklist --tool open-design --dry-run",
        "runtime": "ws product-design-runtime-report --tool open-design --dry-run",
        "review": "ws product-design-run-review --product <current_product> --tool open-design --dry-run",
        "review-write": "ws product-design-run-review --product <current_product> --tool open-design --confirm"
      },
      "safety_class": "DRY_RUN_ONLY",
      "writes_local_files": false,
      "tool_execution": false
    }
  ]
}
