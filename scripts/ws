        if [ -z "${1:-}" ]; then
            echo "Usage: ws open-run <run_id>"
            exit 1
        fi
        RUN_PATH="$RUNS_DIR/$1"
        if [ -d "$RUN_PATH" ]; then
            ls -la "$RUN_PATH"
        elif [ -f "$RUN_PATH" ]; then
            cat "$RUN_PATH"
        else
            echo "Run artifact not found: $RUN_PATH"
            exit 1
        fi
        ;;
    build-status)
        BUILD_RUNS_DIR="$WS_HOME/build_runs"
        if [ -d "$BUILD_RUNS_DIR" ]; then
            ls -1 "$BUILD_RUNS_DIR" | tail -n 10
        else
            echo "No build_runs directory found: $BUILD_RUNS_DIR"
        fi
