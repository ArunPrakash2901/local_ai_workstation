#!/bin/bash

# Unified Workstation Command

# Robustly determine WS_HOME
if [ -z "${WS_HOME:-}" ]; then
    SOURCE="${BASH_SOURCE[0]}"
    while [ -h "$SOURCE" ]; do
        DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
        SOURCE="$(readlink "$SOURCE")"
        [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
    done
    _SCRIPTS_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
    export WS_HOME="$(cd "$_SCRIPTS_DIR/.." >/dev/null 2>&1 && pwd)"
fi

if [ -f "$WS_HOME/scripts/ws_env.sh" ]; then
    # shellcheck source=/mnt/d/_ai_brain/scripts/ws_env.sh
    source "$WS_HOME/scripts/ws_env.sh"
fi

WS_HOME=${WS_HOME:-"/mnt/d/_ai_brain"}
SCRIPTS_DIR="$WS_HOME/scripts"
RUNS_DIR="$WS_HOME/runs"
SUBCOMMAND=$1
shift

case "$SUBCOMMAND" in
    help|--help|-h)
        echo "AI Workstation Unified Command (ws)"
        echo "-----------------------------------"
        echo "Usage: ws <subcommand> [args] [flags]"
        echo ""
        echo "Projects:"
        echo "  projects            List all registered projects"
        echo "  project <key>       Show project metadata"
        echo ""
        echo "Intelligence:"
        echo "  ask <key> <q>       Ask project-specific question"
        echo "  global <q>          Ask cross-project global question"
        echo "  graph <key|global>  Query knowledge graph directly"
        echo "  audit <key>         Perform project audit"
        echo "  debug <key> <log>   Debug error log"
        echo "  task <key> <file>   Run bounded implementation task"
        echo "  build <key> <file>  Run bounded local-first product build loop"
        echo ""
        echo "Models & KV:"
        echo "  model               Show active model configuration"
        echo "  models              List available model profiles"
        echo "  use <profile>       Switch active model profile"
        echo "  warm [profile]      Warm model safely"
        echo "  unload              Unload models from VRAM"
        echo "  kv                  List KV cache profiles"
        echo "  kvuse <profile>     Switch active KV cache profile"
        echo "  daily               Restore safe daily profile"
        echo "  moe                 List MoE/big-model lab profiles"
        echo "  ready               Run daily readiness check and save report"
        echo ""
        echo "Frontier Escalation:"
        echo "  frontier            Show status of frontier providers"
        echo "  packet <key> <q>    Create escalation packet (local first)"
        echo "  redact <packet>     Safety scan a packet before manual escalation"
        echo "  escalate <prov> <p> Send SAFE packet explicitly to gemini/codex"
        echo ""
        echo "Tasks:"
        echo "  task-new            Create canonical task in tasks/inbox"
        echo "  task-split <prd>    Split structured PRDs into generated tasks"
        echo "  task-status         Show task lifecycle counts and recent tasks"
        echo "  task-next [project] Print next task source and path"
        echo "  task-review <f> --with codex  Create review packet for a task"
        echo "  task-complete <f> [n] Mark task completed"
        echo "  task-block <f> <r>  Mark task blocked with reason"
        echo ""
        echo "Product Lane:"
        echo "  product-new --title <t> --type <type> [--id <id>] Create product registry record"
        echo "  product-list        List product registry records"
        echo "  product-status <id> Show one product registry record"
        echo "  product-help        Show Product Lane Phase 0 quick help"
        echo "  product-questions --type <type> --dry-run  Preview static intake questions"
        echo "  product-intake --type <type> --dry-run     Preview intake flow (no writes)"
        echo "  product-intake --product <id> --confirm    Start intake (writes templates)"
        echo "  product-answer-import --product <id> --file <answers_file> --confirm  Import intake answers and classify readiness"
        echo "  product-scope --product <id> --dry-run     Preview deterministic scope draft (no writes)"
        echo "  product-scope-change --product <id> --file <change_file> --dry-run Preview deterministic scope change impact"
        echo "  product-scope-change --product <id> --file <change_file> --confirm Record scope change decision and stale metadata"
        echo "  product-scope-revision --product <id> --dry-run Preview revised scope from confirmed change decisions"
        echo "  product-scope-revision --product <id> --confirm Write versioned revised scope lock and active scope metadata"
        echo "  product-lock-scope --product <id> --confirm Lock immutable scope artifact"
        echo "  product-prd --product <id> --dry-run       Preview deterministic PRD from locked scope"
        echo "  product-prd --product <id> --confirm       Write deterministic PRD draft from locked scope"
        echo "  product-prd-revision --product <id> --dry-run Preview deterministic PRD revision from active scope"
        echo "  product-prd-review --product <id> --dry-run Preview deterministic PRD review report"
        echo "  product-prd-approve --product <id> --confirm Approve PRD metadata after PASS review"
        echo "  product-prd-status --product <id>          Show pure-read PRD artifact status"
        echo "  product-wireframe --product <id> --dry-run Preview deterministic text/ASCII wireframes"
        echo "  product-wireframe-review --product <id> --dry-run Preview deterministic wireframe review"
        echo "  product-tech-plan --product <id> --dry-run Preview deterministic technical plan gated by PRD/wireframe"
        echo "  product-tech-plan --product <id> --confirm Write deterministic technical plan artifact and metadata"
        echo "  product-tech-plan-review --product <id> --dry-run Review active technical plan deterministically"
        echo "  product-implementation-plan --product <id> --dry-run Preview implementation planning readiness gate"
        echo "  product-implementation-plan-review --product <id> --dry-run Review implementation plan deterministically"
        echo "  product-implementation-exchange-preview --product <id> --dry-run Preview implementation exchange packet draft"
        echo ""
        echo "Exchange Lane (Phase 0):"
        echo "  exchange-new --target <t> --task-type <type> --summary <s> [--dry-run|--confirm]"
        echo "  exchange-list       List exchange packet directories and status"
        echo "  exchange-status <id> Show one exchange packet status from exchange.yaml"
        echo "  exchange-dispatch --exchange <id> --dry-run Preview dispatch readiness without execution"
        echo "  exchange-dispatch --exchange <id> --target codex_cli --confirm Run guarded REVIEW_ONLY Codex adapter dispatch"
        echo "  exchange-adapter-preview --exchange <id> --target codex_cli --dry-run Preview Codex adapter invocation without execution"
        echo "  exchange-import-result --exchange <id> --file <f> [--dry-run|--confirm] Import result text into exchange artifacts"
        echo ""
        echo "Runtime Sessions (Phase 4 preview slice):"
        echo "  session-list       List runtime session manifests"
        echo "  session-status <id> Show one runtime session manifest status"
        echo "  session-plan --session <id> --runtime <type> --adapter <adapter> --dry-run  Preview managed runtime session plan"
        echo "  session-plan --session <id> --runtime <type> --adapter <adapter> --confirm  Create planned runtime session metadata"
        echo "  session-start --session <id> --dry-run  Preview runtime session start without starting a process"
        echo "  session-cleanup --dry-run  Preview cleanup candidates without deleting files"
        echo ""
        echo "Feature Strongholds:"
        echo "  feature-new <k>     Create a local-only feature stronghold"
        echo "  feature-plan <id>   Build/update a local-only feature plan"
        echo "  feature-validate <id> Validate local-only feature readiness"
        echo "  feature-handoff <id> Create a feature-aware local handoff packet"
        echo "  feature-report <id> Generate a local feature summary report"
        echo "  feature-status      List recent feature strongholds"
        echo "  feature-local-review <id> --model <m> Run local Ollama reasoning gate"
        echo "  feature-architect-handoff <id> --target <t> Create senior architect handoff"
        echo "  feature-run <id> --dry-run Preview future supervised run eligibility"
        echo ""
        echo "Generic Strongholds (Phase 5):"
        echo "  stronghold-new --type <t> --title <t> Create generic stronghold"
        echo "  stronghold-status    List recent generic strongholds"
        echo "  stronghold-intake <id> Generate domain-specific intake questions"
        echo "  stronghold-intake-import <id> --from-file <f> Import intake answers"
        echo "  stronghold-architect-handoff <id> --target <t> Create senior architect handoff"
        echo "  stronghold-plan-import <id> --from-handoff <h> Import architect plan"
        echo "  stronghold-local-checklist <id> --model <m> Generate operational checklist"
        echo "  stronghold-report <id> Generate summary report"
        echo "  stronghold-decision <id> Classify next safe state/action"
        echo ""
        echo "Domain Specific Runners (Phase 6):"
        echo "  knowledge-inventory --target <t> --dry-run  Preview knowledge raw-data inventory"
        echo "  learning-run <id> --session --dry-run Plan learning session"
        echo "  learning-import-answers <id> --from-file <f> Import completed answers"
        echo "  learning-assess <id> --model <m> Assess imported answers"
        echo "  learning-decision <id> Classify next learning action"
        echo "  learning-review-session <id> --dry-run Plan review session"
        echo "  learning-advance <id> Advance to next learning task"
        echo "  learning-action-pack <id> --dry-run Generate dry-run action pack v1"
        echo "  learning-confirm <id> --action-id <id> [--dry-run | --confirm] Confirm dry-run action"
        echo "  learning-ledger-repair <id> [--dry-run | --repair-ledger] Repair legacy confirmation ledger"
        echo "  learning-pointer-plan <id> --dry-run Generate next task pointer update plan v1"
        echo "  learning-advancement-plan <id> --dry-run Generate advancement readiness plan v1"
        echo "  learning-advancement-review <id> [--dry-run | --create-packet] Generate human review packet v1"
        echo "  learning-state-sync-plan <id> --dry-run Generate state sync plan v1"
        echo "  learning-state-sync-apply <id> [--dry-run | --confirm-sync] Apply state sync plan v1"
        echo "  learning-review-checklist <id> --packet-id <p> [--dry-run-init | --init-checklist | --show] Manage human review checklist v1"



        echo ""
        echo "Research Runner (Phase 7):"
        echo "  research-run <id> --review-paper --dry-run Plan paper review"
        echo "  research-decision <id> Classify next research action"
        echo "  research-add-source <id> --source-text <f> --label <l> Register new source"
        echo ""
        echo "Quant Trading Lane (Phase 6+):"
        echo "  quant dashboard            Show read-only research dashboard"
        echo "  quant idea-intake-dry-run  [--title <t>] [--idea-file <f>] Dry-run idea intake"
        echo "  quant reports              List completed research milestone reports"
        echo "  quant artifacts            Summarize Quant artifact counts"
        echo "  quant lineage <id>         Lookup lineage for a specific artifact ID"
        echo "  quant cheatsheet           Show Quant operator cheatsheet"
        echo "  quant status               Show high-level research status"
        echo "  quant list-tools           List standalone research CLIs"
        echo "  quant synthetic-status     Show synthetic execution status"
        echo "  quant gates-status         Show pre-backtest gate statuses"
        echo "  quant data-contract-check  [--dry-run] Validate YAML contracts"
        echo "  quant data-schema-check    [--dry-run] Validate sample OHLCV schema"
        echo ""
        echo "  SAFETY NOTICE: Real backtests, approvals, and data downloads are BLOCKED"
        echo "  in 'ws quant' and remain restricted to standalone standalone research CLIs."
        echo "  quant data-freshness-check --latest <ts> [--dry-run] Check data freshness"
        echo "  quant data-ingest-fixture  --symbol SPY --start <iso> --end <iso> [--format <f>] [--write-fixture]"
        echo "  quant dataset-catalog      [--dry-run] Scan Quant dataset catalog"
        echo "  quant dataset-profile      --path <p> [--dry-run] Profile a Quant dataset"
        echo "  quant feature-contract-check [--dry-run] Validate feature building contract"
        echo "  quant feature-build        --input <p> --features <f> [--format <fmt>] [--write-features]"
        echo "  quant persistence-capabilities [--dry-run] Detect local persistence libraries"
        echo "  quant analytics-capabilities   [--dry-run] Detect local analytics libraries"
        echo "  quant paths-check          [--dry-run] Verify approved quant paths"
        echo ""
        echo "Agent & Loops:"
        echo "  apply-ready <k> <t> Check if task is ready for agent-run"
        echo "  agent-run <k> <t> [flags] Run bounded Windows-native agent task"
        echo "  agent-status        Show Windows agent orchestrator status"
        echo "  agent-canary        Run Windows-native Codex canary"
        echo "  agent-import <run>  Inspect an agent run folder"
        echo "  agent-validate      Run workstation agent contract validation"
        echo "  agent-hygiene       Audit agent branches and run folders"
        echo "  agent-mark-stale-reviewed <run> Mark stuck run as historical"
        echo "  loop-plan <k> <t>   Check local-loop eligibility without starting it"
        echo "  worktree-plan <k> <t> Preview future isolated worktree without creating it"
        echo "  worktree-create <k> <t> Preview or apply supervised isolated worktree creation"
        echo "  worktree-review <path> Review an existing worktree without modifying it"
        echo "  worktree-sync <path> --dry-run Preview what is needed to sync a worktree"
        echo "  worktree-status     Summarize read-only worktree state and recent plans"
        echo "  loop-status         Show latest local-loop status"
        echo "  loop-start <k> <t>  Start supervised local-only planning loop"
        echo "  handoff-new <k> <t> Create local-only handoff packet artifacts"
        echo "  handoff-copy <id>   Copy a local handoff prompt to Windows clipboard"
        echo "  handoff-import <id> Import clipboard text into a local handoff packet"
        echo "  handoff-review <id> Run deterministic local review on an imported response"
        echo "  handoff-status      List recent local handoff packets"
        echo ""
        echo "System:"
        echo "  status              High-level health/status check"
        echo "  tui                 Launch read-only operator dashboard"
        echo "  runs                List recent run folders"
        echo "  open-run <id>       Show paths for a specific run"
        echo "  aliases             Show legacy aliases"
        echo "  paths               Show path abstraction and migration status"
        echo "  audit-workstation   Read-only audit of workstation infrastructure"
        echo "  cleanup-plan        Generate read-only cleanup plan"
        echo "  cleanup-apply       Archive approved cleanup candidates; requires --apply"
        echo "  cleanup-status      Show latest cleanup reports and unresolved issues"
        echo "  build-status        Show latest build loop status"
        echo "  build-runs          List recent build run folders"
        echo "  open-build <id>     Show artifacts for a build run"
        echo ""
        echo "Global Flags (passed to scripts):"
        echo "  --profile <p>, --model <m>, --kv <k>, --context <c>"
        ;;
    projects)
        bash "$SCRIPTS_DIR/ai_list_projects.sh" "$@"
        ;;
    project)
        bash "$SCRIPTS_DIR/ai_project.sh" "$@"
        ;;
    ask)
        bash "$SCRIPTS_DIR/ai_ask.sh" "$@"
        ;;
    global)
        bash "$SCRIPTS_DIR/ai_global_ask.sh" "$@"
        ;;
    graph)
        bash "$SCRIPTS_DIR/ai_graph.sh" "$@"
        ;;
    audit)
        bash "$SCRIPTS_DIR/ai_audit.sh" "$@"
        ;;
    debug)
        bash "$SCRIPTS_DIR/ai_debug.sh" "$@"
        ;;
    task)
        bash "$SCRIPTS_DIR/ai_run_task.sh" "$@"
        ;;
    build)
        bash "$SCRIPTS_DIR/ws_build.sh" "$@"
        ;;
    agent-status)
        powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$(wslpath -w "$SCRIPTS_DIR/ws_agent_status.ps1")" "$@"
        ;;
    agent-canary)
        powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$(wslpath -w "$SCRIPTS_DIR/ws_agent_canary.ps1")" "$@"
        ;;
    apply-ready)
        bash "$SCRIPTS_DIR/ws_apply_ready.sh" "$@"
        ;;
    agent-run)
        if [ $# -lt 2 ]; then
            echo "Usage: ws agent-run <project_key> <task_file> [flags]"
            exit 1
        fi
        AGENT_PROJECT="$1"
        AGENT_TASK="$2"
        shift 2
        case "$AGENT_TASK" in
            [A-Za-z]:[!\\/]*)
                echo "Error: task file looks like an unquoted Windows path that Bash mangled."
                echo "Use /mnt/d/... from WSL, or quote the Windows path."
                exit 2
                ;;
        esac
        to_win_path() {
            case "$1" in
                /mnt/*) wslpath -w "$1" ;;
                *) printf '%s' "$1" ;;
            esac
        }
        AGENT_TASK_WIN="$(to_win_path "$AGENT_TASK")"
        AGENT_ARGS=( -NoProfile -ExecutionPolicy Bypass -File "$(wslpath -w "$SCRIPTS_DIR/ws_agent_run.ps1")" -Command Run -ProjectKey "$AGENT_PROJECT" -TaskFile "$AGENT_TASK_WIN" )
        while [ $# -gt 0 ]; do
            case "$1" in
                --mode) AGENT_ARGS+=( -Mode "$2" ); shift 2 ;;
                --branch) AGENT_ARGS+=( -Branch ); shift ;;
                --max-files) AGENT_ARGS+=( -MaxFiles "$2" ); shift 2 ;;
                --max-minutes) AGENT_ARGS+=( -MaxMinutes "$2" ); shift 2 ;;
                --stop-on-fail) AGENT_ARGS+=( -StopOnFail ); shift ;;
                --dry-run) AGENT_ARGS+=( -DryRun ); shift ;;
                --tests) AGENT_ARGS+=( -Tests "$2" ); shift 2 ;;
                *) AGENT_ARGS+=( "$1" ); shift ;;
            esac
        done
        powershell.exe "${AGENT_ARGS[@]}"
        ;;
    agent-run-worktree)
        bash "$SCRIPTS_DIR/ws_agent_run_worktree.sh" "$@"
        ;;
    agent-import)
        powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$(wslpath -w "$SCRIPTS_DIR/ws_agent_import.ps1")" "$@"
        ;;
    agent-validate)
        bash "$SCRIPTS_DIR/ws_agent_validate.sh" "$@"
        ;;
    agent-hygiene)
        bash "$SCRIPTS_DIR/ws_agent_hygiene.sh" "$@"
        ;;
    agent-mark-stale-reviewed)
        bash "$SCRIPTS_DIR/ws_agent_mark_stale_reviewed.sh" "$@"
        ;;
    model)
        bash "$SCRIPTS_DIR/ai_model_current.sh" "$@"
        ;;
    models)
        bash "$SCRIPTS_DIR/ai_models.sh" "$@"
        ;;
    use)
        bash "$SCRIPTS_DIR/ai_model_use.sh" "$@"
        ;;
    warm)
        bash "$SCRIPTS_DIR/ai_model_warm.sh" "$@"
        ;;
    unload)
        bash "$SCRIPTS_DIR/ai_model_unload.sh" "$@"
        ;;
    kv)
        bash "$SCRIPTS_DIR/ai_kv_profiles.sh" "$@"
        ;;
    kvuse)
        bash "$SCRIPTS_DIR/ai_kv_use.sh" "$@"
        ;;
    daily)
        bash "$SCRIPTS_DIR/ai_daily_restore.sh" "$@"
        ;;
    ready)
        bash "$SCRIPTS_DIR/ws_readiness.sh" "$@"
        ;;
    moe)
        # Assuming ai_moe_list.sh was supposed to be implemented or we use ai_models with filte
        # For now, map to ai_models.sh if ai_moe_list doesn't exist
        if [ -f "$SCRIPTS_DIR/ai_moe_list.sh" ]; then
            bash "$SCRIPTS_DIR/ai_moe_list.sh" "$@"
        else
            bash "$SCRIPTS_DIR/ai_models.sh" | grep -E "YES.*YES|Lab|Profile"
        fi
        ;;
    status)
        # Combine health check and current model
        powershell.exe -File "D:/_ai_brain/scripts/check_health.ps1"
        bash "$SCRIPTS_DIR/ai_model_current.sh"
        ;;
    tui)
        bash "$SCRIPTS_DIR/ws_tui.sh" "$@"
        ;;
    runs)
        if compgen -G "$RUNS_DIR/*" > /dev/null; then
            ls -dt "$RUNS_DIR"/* | head -n 10
        else
            echo "No run folders found under $RUNS_DIR"
        fi
        ;;
    open-run)
        RUN_ID=$1
        if [ -z "$RUN_ID" ]; then echo "Usage: ws open-run <id_or_latest>"; exit 1; fi
        if [ "$RUN_ID" == "latest" ]; then
            TARGET=$(ls -dt "$RUNS_DIR"/* 2>/dev/null | head -n 1)
        else
            TARGET=$(ls -d "$RUNS_DIR"/*"$RUN_ID"* 2>/dev/null | head -n 1)
        fi
        if [ -d "$TARGET" ]; then
            echo "Run Folder: $TARGET"
            echo "Context:    $TARGET/context_pack.md"
            echo "Graph:      $TARGET/graph_context.md"
            echo "Prompt:     $TARGET/prompt.md"
            echo "User Prompt:$TARGET/user_prompt.md"
            echo "Answer:     $TARGET/answer.md"
            echo "Summary:    $TARGET/run_summary.yaml"
        else
            echo "Error: Run $RUN_ID not found."
            exit 1
        fi
        ;;
    aliases)
        echo "Legacy aliases (supported but ws preferred):"
        echo "ailist, aiproj, aiask, aiglobal, aigraph, aiaudit, aidebug, aitask"
        echo "aimodels, aimodel, aiuse, aikv, aidaily"
        ;;
    paths)
        bash "$SCRIPTS_DIR/ws_path_status.sh"
        ;;
    audit-workstation)
        bash "$SCRIPTS_DIR/ws_audit_workstation.sh" "$@"
        ;;
    cleanup-plan)
        bash "$SCRIPTS_DIR/ws_cleanup_plan.sh" "$@"
        ;;
    cleanup-apply)
        bash "$SCRIPTS_DIR/ws_cleanup_apply.sh" "$@"
        ;;
    cleanup-status)
        bash "$SCRIPTS_DIR/ws_cleanup_status.sh" "$@"
        ;;
    build-status)
        LATEST=$(find "$WS_HOME/build_runs" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -n 1 | cut -d' ' -f2-)
        if [ -z "$LATEST" ]; then
            echo "No build runs found."
        else
            echo "Latest build run: $LATEST"
            echo -n "Status: "
            cat "$LATEST/status.txt" 2>/dev/null || echo "unknown"
            [ -f "$LATEST/build_report.md" ] && echo "Report: $LATEST/build_report.md"
        fi
        ;;
    build-runs)
        if find "$WS_HOME/build_runs" -mindepth 1 -maxdepth 1 -type d | grep -q .; then
            find "$WS_HOME/build_runs" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' | sort -nr | head -n 20 | cut -d' ' -f2-
        else
            echo "No build runs found."
        fi
        ;;
    open-build)
        RUN_ID=${1:-}
        if [ -z "$RUN_ID" ]; then echo "Usage: ws open-build <latest|run_id>"; exit 1; fi
        if [ "$RUN_ID" = "latest" ]; then
            TARGET=$(find "$WS_HOME/build_runs" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -n 1 | cut -d' ' -f2-)
        else
            TARGET=$(find "$WS_HOME/build_runs" -mindepth 1 -maxdepth 1 -type d -name "*$RUN_ID*" -print 2>/dev/null | head -n 1)
        fi
        if [ -z "$TARGET" ] || [ ! -d "$TARGET" ]; then
            echo "Build run not found: $RUN_ID"
            exit 1
        fi
        echo "-----------------------------------------"
        echo " Build Run Summary: $(basename "$TARGET")"
        echo "-----------------------------------------"
        if [ -f "$TARGET/build_report.md" ]; then
            # Print Summary section (exclude the header itself and stop at Artifacts)
            sed -n '/## Summary/,/## Artifacts/p' "$TARGET/build_report.md" | grep -v "##" | sed '/^[[:space:]]*$/d'
            echo ""
            # Print Final Status
            echo -n "Final Status: "
            cat "$TARGET/status.txt" 2>/dev/null || echo "unknown"
            echo ""
            # Print Recommendation
            echo "Recommendation:"
            sed -n '/## Task Lifecycle Recommendation/,$p' "$TARGET/build_report.md" | grep -v "##" | sed '/^[[:space:]]*$/d'
        else
            echo "Status: $(cat "$TARGET/status.txt" 2>/dev/null || echo "unknown")"
            echo "Report missing: $TARGET/build_report.md"
        fi
        echo "-----------------------------------------"
        echo "All artifacts in: $TARGET"
        ;;
    task-new)
        bash "$SCRIPTS_DIR/ws_task_new.sh" "$@"
        ;;
    task-split)
        bash "$SCRIPTS_DIR/ws_task_split.sh" "$@"
        ;;
    task-status)
        bash "$SCRIPTS_DIR/ws_task_status.sh" "$@"
        ;;
    task-next)
        bash "$SCRIPTS_DIR/ws_task_next.sh" "$@"
        ;;
    task-review)
        bash "$SCRIPTS_DIR/ws_task_review_packet.sh" "$@"
        ;;
    task-complete)
        bash "$SCRIPTS_DIR/ws_task_complete.sh" "$@"
        ;;
    task-block)
        bash "$SCRIPTS_DIR/ws_task_block.sh" "$@"
        ;;
    product-new)
        python3 "$SCRIPTS_DIR/ws_product_new.py" "$@"
        ;;
    product-list)
        python3 "$SCRIPTS_DIR/ws_product_list.py" "$@"
        ;;
    product-status)
        python3 "$SCRIPTS_DIR/ws_product_status.py" "$@"
        ;;
    product-help)
        python3 "$SCRIPTS_DIR/ws_product_help.py" "$@"
        ;;
    product-questions)
        python3 "$SCRIPTS_DIR/ws_product_questions.py" "$@"
        ;;
    product-intake)
        python3 "$SCRIPTS_DIR/ws_product_intake.py" "$@"
        ;;
    product-answer-import)
        python3 "$SCRIPTS_DIR/ws_product_answer_import.py" "$@"
        ;;
    product-scope)
        python3 "$SCRIPTS_DIR/ws_product_scope.py" "$@"
        ;;
    product-scope-change)
        python3 "$SCRIPTS_DIR/ws_product_scope_change.py" "$@"
