            ls -1 "$BUILD_RUNS_DIR"
        else
            echo "No build_runs directory found: $BUILD_RUNS_DIR"
        fi
        ;;
    open-build)
        if [ -z "${1:-}" ]; then
            echo "Usage: ws open-build <build_id>"
            exit 1
        fi
        BUILD_PATH="$WS_HOME/build_runs/$1"
        if [ -d "$BUILD_PATH" ]; then
            ls -la "$BUILD_PATH"
        elif [ -f "$BUILD_PATH" ]; then
