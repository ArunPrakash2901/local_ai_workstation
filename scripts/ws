    quant)
        # Quant foundation CLI (Wave 1)
        PYTHON_EXEC="${PYTHON_EXEC:-python3}"
        # Ensure we use the workstation venv if available
        if [ -x "$WS_HOME/runtimes/workstation_venv/bin/python3" ]; then
            PYTHON_EXEC="$WS_HOME/runtimes/workstation_venv/bin/python3"
        elif [ -x "$WS_HOME/runtimes/workstation_venv/Scripts/python.exe" ]; then
             PYTHON_EXEC="$WS_HOME/runtimes/workstation_venv/Scripts/python.exe"
        fi
        
        case "$1" in
            status|list-tools|synthetic-status|gates-status|dashboard|reports|artifacts|lineage|cheatsheet)
                PYTHONPATH="$WS_HOME/scripts" "$PYTHON_EXEC" "$WS_HOME/scripts/quant/ws_quant_summary.py" "$@"
                ;;
            idea-intake-dry-run)
                # Check for forbidden --write flag
                for arg in "$@"; do
                    if [[ "$arg" == "--write" ]]; then
                        echo "[SAFETY BLOCK] --write is strictly forbidden in 'ws quant' in this milestone."
                        exit 1
                    fi
                done
                # Force --dry-run and call the standalone CLI
                shift
                PYTHONPATH="$WS_HOME/scripts" "$PYTHON_EXEC" "$WS_HOME/scripts/quant/idea_cli.py" idea-intake "$@" --dry-run
                ;;
            *)
                PYTHONPATH="$WS_HOME/scripts" "$PYTHON_EXEC" -m quant.cli "$@"
                ;;
        esac
        ;;
    loop-plan)
        bash "$SCRIPTS_DIR/ws_loop_plan.sh" "$@"
        ;;
    worktree-plan)
        bash "$SCRIPTS_DIR/ws_worktree_plan.sh" "$@"
        ;;
